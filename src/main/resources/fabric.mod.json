{
	"schemaVersion": 1,
	"id": "defense-of-the-craft",
	"version": "${version}",
	"name": "Defense of the Craft",
	"description": "Immersive survival-oriented Dota-based Minecraft mod",
	"authors": [
		"DetectiveKaktus"
	],
	"contact": {
		"sources": "https://github.com/detectivekaktus/dotc"
	},
	"license": "MIT",
	"icon": "assets/defense-of-the-craft/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"net.detectivekaktus.DefenseOfTheCraft"
		],
		"client": [
			"net.detectivekaktus.client.DefenseOfTheCraftClient"
		],
		"fabric-datagen": [
			"net.detectivekaktus.client.DefenseOfTheCraftDataGenerator"
		]
	},
	"mixins": [
		"defense-of-the-craft.player.mixins.json",
		{
			"config": "defense-of-the-craft.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.6",
		"minecraft": "~1.21.1",
		"java": ">=21",
		"fabric-api": "*"
	},
	"suggests": {
		"damagenumbers": ">=1.4.1"
	}
}